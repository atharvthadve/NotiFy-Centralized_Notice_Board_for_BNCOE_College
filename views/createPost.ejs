<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Notice — NotiFy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="createPost.css">
</head>
<body>

  <!-- Loading overlay -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner"></div>
    <div class="loading-text" id="loadingText">Notice post ho raha hai...</div>
    <div class="loading-sub" id="loadingSub">File Cloudinary pe upload ho rahi hai, thoda wait karo</div>
  </div>

  <!-- Toast -->
  <div class="toast error" id="toast">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <span id="toastMsg">Kuch fields khaali hain!</span>
  </div>

  <!-- Topbar -->
  <nav class="topbar">
    <div class="brand">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
      </div>
      <span class="brand-name">Notice Board</span>
      <span class="admin-chip">Admin</span>
    </div>
    <a href="/admin" class="back-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Dashboard
    </a>
  </nav>

  <!-- Page Header -->
  <div class="page-header">
    <h1>Create <span>Notice</span></h1>
    <p>Fill in the details below. Notice will be visible to all students immediately.</p>
  </div>

  <!-- Steps -->
  <div class="steps">
    <div class="step active" id="step1">
      <div class="step-dot">1</div>
      <span>Notice Details</span>
    </div>
    <div class="step-line" id="line1"></div>
    <div class="step" id="step2">
      <div class="step-dot">2</div>
      <span>Attachment</span>
    </div>
    <div class="step-line" id="line2"></div>
    <div class="step" id="step3">
      <div class="step-dot">3</div>
      <span>Author Info</span>
    </div>
  </div>

  <!-- Form -->
  <div class="form-wrap">
    <div class="form-card">
      <form action="/student" method="POST" enctype="multipart/form-data" autocomplete="off" id="noticeForm" novalidate>

        <!-- Section 1: Notice Details -->
        <div class="section-panel">
          <div class="section-head">
            <div class="section-icon blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <span class="section-title">Notice Details</span>
          </div>

          <div class="field-group">
            <label for="title">Title <span class="req">*</span></label>
            <input type="text" id="title" name="title" placeholder="Enter notice title" required />
            <div class="field-footer">
              <span></span><span class="char-count" id="titleCount">0 / 120</span>
            </div>
          </div>

          <div class="field-group">
            <label for="description">Description <span class="req">*</span></label>
            <textarea id="description" name="description" placeholder="Write the full notice content here..." maxlength="1000" required></textarea>
            <div class="field-footer">
              <span></span><span class="char-count" id="descCount">0 / 1000</span>
            </div>
          </div>
        </div>

        <!-- Section 2: Attachment -->
        <div class="section-panel">
          <div class="section-head">
            <div class="section-icon orange">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
            </div>
            <span class="section-title">Attachment <span style="font-weight:400;font-style:italic;text-transform:none;font-size:.72rem;">(optional)</span></span>
          </div>

          <div class="field-group">
            <label for="file">Upload File</label>
            <div class="drop-zone" id="dropZone">
              <input type="file" id="file" name="file" accept="image/jpeg,image/png,image/webp,.pdf" />
              <div class="drop-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <div class="drop-text">Click to upload or drag & drop</div>
              <div class="drop-sub">JPG, PNG, WEBP, PDF — max 5MB</div>
            </div>
            <div class="file-preview" id="filePreview">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span id="fileName">file.pdf</span>
              <button type="button" class="file-remove" id="fileRemove">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          </div>

          <div class="or-divider">OR</div>

          <div class="field-group">
            <label for="url">Resource URL <span class="opt">(optional)</span></label>
            <div class="input-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <input type="text" id="url" name="url" placeholder="e.g. https://shorturl.at/KJcEX"/>
            </div>
          </div>
        </div>

        <!-- Section 3: Author Info -->
        <div class="section-panel">
          <div class="section-head">
            <div class="section-icon green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="section-title">Author Info</span>
          </div>

          <div class="field-row">
            <div class="field-group">
              <label for="author">Author Name <span class="req">*</span></label>
              <input type="text" id="author" name="author" placeholder="Author Name" required />
            </div>
            <div class="field-group">
              <label for="department">Department <span class="req">*</span></label>
              <input type="text" id="department" name="department" placeholder="e.g. CSE, 2nd Year, All Branches" required />
            </div>
          </div>
        </div>

        <!-- Submit Bar -->
        <div class="submit-bar">
          <p class="submit-note">Fields marked <span>*</span> are required</p>
          <button type="submit" class="submit-btn" id="submitBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4 20-7z"/></svg>
            Post Notice
          </button>
        </div>

      </form>
    </div>
  </div>

  <script>
    // Char counters
    function setupCounter(inputId, counterId, max) {
      const input = document.getElementById(inputId);
      const counter = document.getElementById(counterId);
      input.addEventListener('input', () => {
        const len = input.value.length;
        counter.textContent = len + ' / ' + max;
        counter.className = 'char-count' + (len > max * .9 ? (len >= max ? ' over' : ' warn') : '');
      });
    }
    setupCounter('title', 'titleCount', 120);
    setupCounter('description', 'descCount', 1000);

    //  Progress Steps
    function updateSteps() {
      const title = document.getElementById('title').value.trim();
      const desc  = document.getElementById('description').value.trim();
      const author = document.getElementById('author').value.trim();
      const dept   = document.getElementById('department').value.trim();

      const s1 = document.getElementById('step1');
      const s2 = document.getElementById('step2');
      const s3 = document.getElementById('step3');
      const l1 = document.getElementById('line1');
      const l2 = document.getElementById('line2');

      if (title && desc) {
        s1.className = 'step done';
        s1.querySelector('.step-dot').innerHTML = '✓';
        l1.className = 'step-line done';
        s2.className = 'step active';
      }
      if (author && dept) {
        s3.className = 'step done';
        s3.querySelector('.step-dot').innerHTML = '✓';
        l2.className = 'step-line done';
      }
    }
    ['title','description','author','department'].forEach(id => {
      document.getElementById(id).addEventListener('input', updateSteps);
    });

    // File drop zone
    const dropZone   = document.getElementById('dropZone');
    const fileInput  = document.getElementById('file');
    const filePreview = document.getElementById('filePreview');
    const fileName   = document.getElementById('fileName');
    const fileRemove = document.getElementById('fileRemove');

    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) showFile(fileInput.files[0]);
    });
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault(); dropZone.classList.remove('drag-over');
      const f = e.dataTransfer.files[0];
      if (f) { const dt = new DataTransfer(); dt.items.add(f); fileInput.files = dt.files; showFile(f); }
    });
    fileRemove.addEventListener('click', () => {
      fileInput.value = ''; filePreview.classList.remove('show');
      dropZone.style.display = '';
    });
    function showFile(f) {
      fileName.textContent = f.name;
      filePreview.classList.add('show');
      dropZone.style.display = 'none';
    }

    //  Toast
    function showToast(msg, type='error') {
      const t = document.getElementById('toast');
      const m = document.getElementById('toastMsg');
      t.className = 'toast ' + type;
      m.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3500);
    }

    // Form submit 
    document.getElementById('noticeForm').addEventListener('submit', function(e) {
      const title  = document.getElementById('title').value.trim();
      const desc   = document.getElementById('description').value.trim();
      const author = document.getElementById('author').value.trim();
      const dept   = document.getElementById('department').value.trim();

      if (!title || !desc || !author || !dept) {
        e.preventDefault();
        showToast('Saare required fields fill karo!');
        return;
      }

      const hasFile = fileInput.files.length > 0;
      document.getElementById('loadingText').textContent = hasFile ? 'File upload ho rahi hai...' : 'Notice save ho raha hai...';
      document.getElementById('loadingSub').textContent = hasFile ? 'Cloudinary pe upload chal raha hai, thoda wait karo.' : 'Database mein save ho raha hai...';
      document.getElementById('loadingOverlay').classList.add('show');
      document.getElementById('submitBtn').disabled = true;
    });
  </script>

</body>
</html>
