<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Notice Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { 
	box-sizing: border-box; margin: 0; padding: 0; 
	}

    :root {
      --indigo:      #4f46e5;
      --indigo-dark: #3730a3;
      --indigo-light:#eef2ff;
      --indigo-mid:  #818cf8;
      --violet:      #7c3aed;
      --red:         #e11d48;
      --red-light:   #fff1f2;
      --red-mid:     #fb7185;
      --coral:       #f97316;
      --bg:          #f8f7ff;
      --surface:     #ffffff;
      --border:      rgba(79,70,229,0.10);
      --text-dark:   #1e1b4b;
      --text-soft:   #6d6a8a;
      --text-muted:  #a5a3bb;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      position: relative;
      overflow: hidden;
    }

    /* Background blobs */
    body::before {
      content: '';
      position: fixed;
      top: -140px; left: -140px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(225,29,72,0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -100px; right: -100px;
      width: 420px; height: 420px;
      background: radial-gradient(circle, rgba(79,70,229,0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 480px;
      text-align: center;
      animation: riseUp 0.7s cubic-bezier(.22,1,.36,1) both;
    }

    /* Big 404 number */
    .big-num {
      font-family: 'Playfair Display', serif;
      font-size: 7rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.04em;
      background: linear-gradient(135deg, var(--red) 0%, var(--red-mid) 50%, var(--coral) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.1rem;
      animation: popIn 0.7s 0.1s cubic-bezier(.34,1.56,.64,1) both;
      user-select: none;
    }

    /* Icon badge */
    .icon-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 72px; height: 72px;
      background: var(--red-light);
      border-radius: 22px;
      border: 1.5px solid rgba(225,29,72,0.14);
      margin-bottom: 1.5rem;
      animation: popIn 0.6s 0.15s cubic-bezier(.34,1.56,.64,1) both;
    }
    .icon-badge svg { width: 34px; height: 34px; color: var(--red); }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.85rem;
      font-weight: 700;
      color: var(--text-dark);
      letter-spacing: -0.02em;
      margin-bottom: 0.6rem;
    }
    h1 span { color: var(--red); }

    .subtitle {
      font-size: 0.9rem;
      color: var(--text-soft);
      font-weight: 300;
      line-height: 1.6;
      max-width: 320px;
      margin: 0 auto 2rem;
    }

    /* Card */
    .glass-card {
      background: var(--surface);
      border-radius: 24px;
      border: 1.5px solid rgba(79,70,229,0.10);
      box-shadow: 0 10px 48px rgba(79,70,229,0.08), 0 2px 8px rgba(0,0,0,0.04);
      padding: 1.75rem;
      margin-bottom: 1.25rem;
      animation: riseUp 0.6s 0.2s ease both;
    }

    .card-label {
      font-size: 0.69rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text-muted); margin-bottom: 1rem;
    }

    /* Quick links */
    .link-list { display: flex; flex-direction: column; gap: 0.75rem; }

    .quick-link {
      display: flex; align-items: center; gap: 0.9rem;
      padding: 0.9rem 1.1rem;
      border-radius: 13px;
      text-decoration: none;
      border: 1.5px solid transparent;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .quick-link:hover { transform: translateY(-2px); }
    .quick-link:active { transform: translateY(0); }

    .quick-link.home {
      background: var(--indigo-light);
      border-color: rgba(79,70,229,0.15);
    }
    .quick-link.home:hover {
      box-shadow: 0 6px 22px rgba(79,70,229,0.16);
      border-color: rgba(79,70,229,0.32);
    }

    .quick-link.student {
      background: var(--red-light);
      border-color: rgba(225,29,72,0.12);
    }
    .quick-link.student:hover {
      box-shadow: 0 6px 22px rgba(225,29,72,0.14);
      border-color: rgba(225,29,72,0.28);
    }

    .link-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .home    .link-icon { background: rgba(79,70,229,0.12); }
    .student .link-icon { background: rgba(225,29,72,0.10); }

    .link-icon svg { width: 19px; height: 19px; }
    .home    .link-icon svg { color: var(--indigo); }
    .student .link-icon svg { color: var(--red); }

    .link-text { flex: 1; text-align: left; }
    .link-text strong { display: block; font-size: 0.92rem; font-weight: 600; }
    .home    .link-text strong { color: var(--text-dark); }
    .student .link-text strong { color: #881337; }

    .link-text span { font-size: 0.76rem; font-weight: 300; }
    .home    .link-text span { color: var(--text-soft); }
    .student .link-text span { color: #be123c; }

    .link-arrow { transition: transform 0.2s; }
    .quick-link:hover .link-arrow { transform: translateX(4px); }
    .link-arrow svg { width: 16px; height: 16px; }
    .home    .link-arrow svg { color: var(--indigo-mid); }
    .student .link-arrow svg { color: var(--red-mid); }

    /* Error code footer */
    .err-code {
      font-size: 0.74rem; color: var(--text-muted);
      margin-top: 0.5rem;
      animation: riseUp 0.6s 0.35s ease both;
    }

    .err-code code {
      font-family: monospace;
      background: var(--indigo-light);
      color: var(--indigo);
      padding: 2px 7px;
      border-radius: 5px;
      font-size: 0.72rem;
    }

    /* Floating dots decoration */
    .dot {
      position: fixed;
      border-radius: 50%;
      opacity: 0.18;
      animation: float 6s ease-in-out infinite;
      pointer-events: none;
    }
    .dot-1 { width: 12px; height: 12px; background: var(--red);    top: 18%; left: 10%; animation-delay: 0s;   }
    .dot-2 { width:  8px; height:  8px; background: var(--indigo); top: 72%; left: 8%;  animation-delay: 1.5s; }
    .dot-3 { width: 10px; height: 10px; background: var(--coral);  top: 30%; right: 9%; animation-delay: 0.8s; }
    .dot-4 { width:  6px; height:  6px; background: var(--violet); top: 65%; right: 7%; animation-delay: 2.2s; }

    @keyframes riseUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(0.65) rotate(-8deg); }
      to   { opacity: 1; transform: scale(1)    rotate(0deg);  }
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-14px); }
    }
  </style>
</head>
<body>

<span class="dot dot-1"></span>
<span class="dot dot-2"></span>
<span class="dot dot-3"></span>
<span class="dot dot-4"></span>

<div class="wrap">


  <div class="icon-badge">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
  </div>

  <h1>Page <span>Not Found</span></h1>
  <p class="subtitle">The page you are looking for doesn't exist. Go back to a safe place.</p>

  <div class="glass-card">
    <p class="card-label">Where would you like to go?</p>
    <div class="link-list">

      <a href="/" class="quick-link home">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <div class="link-text">
          <strong>Go Home</strong>
          <span>Back to the main portal</span>
        </div>
        <div class="link-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>

      <a href="/student" class="quick-link student">
        <div class="link-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <div class="link-text">
          <strong>Student Dashboard</strong>
          <span>View all notices</span>
        </div>
        <div class="link-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>

    </div>
  </div>

  <p class="err-code">Error code <code>HTTP 404</code> &nbsp;·&nbsp; Notice Board System</p>

</div>
</body>
</html>
