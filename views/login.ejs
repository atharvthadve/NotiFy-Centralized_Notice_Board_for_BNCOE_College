<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — Notice Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --indigo: #4f46e5;
      --indigo-d: #3730a3;
      --indigo-l: #eef2ff;
      --indigo-m: #818cf8;
      --coral: #f97316;
      --coral-l: #fff7ed;
      --violet: #7c3aed;
      --red: #e11d48;
      --red-l: #fff1f2;
      --bg: #f8f7ff;
      --surface: #fff;
      --surface-2: #f9f8ff;
      --border: rgba(79, 70, 229, .09);
      --tx: #1e1b4b;
      --tx-s: #6d6a8a;
      --tx-m: #a5a3bb;
      --sh-md: 0 8px 40px rgba(79, 70, 229, .10), 0 2px 8px rgba(0, 0, 0, .04);
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--tx);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* background blobs */
    body::before {
      content: '';
      position: fixed;
      top: -130px;
      left: -130px;
      width: 480px;
      height: 480px;
      background: radial-gradient(circle, rgba(79, 70, 229, .10) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      bottom: -90px;
      right: -90px;
      width: 380px;
      height: 380px;
      background: radial-gradient(circle, rgba(249, 115, 22, .08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 400px;
      animation: up .65s cubic-bezier(.22, 1, .36, 1) both;
    }

    /* header above card */
    .hero {
      text-align: center;
      margin-bottom: 1.75rem;
    }

    .logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 62px;
      height: 62px;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--coral), #fb923c);
      box-shadow: 0 8px 28px rgba(249, 115, 22, .30);
      margin-bottom: 1.1rem;
      animation: pop .6s .15s cubic-bezier(.34, 1.56, .64, 1) both;
    }

    .logo svg {
      width: 28px;
      height: 28px;
      color: #fff;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -.02em;
      color: var(--tx);
    }

    .hero h1 span {
      color: var(--coral);
    }

    .hero p {
      margin-top: .35rem;
      font-size: .85rem;
      color: var(--tx-m);
      font-weight: 300;
    }

    /* card */
    .card {
      background: var(--surface);
      border: 1.5px solid rgba(79, 70, 229, .10);
      border-radius: 22px;
      box-shadow: var(--sh-md);
      padding: 1.75rem;
    }

    .field {
      margin-bottom: 1rem;
    }

    .field:last-of-type {
      margin-bottom: 0;
    }

    label {
      display: block;
      font-size: .75rem;
      font-weight: 600;
      color: var(--tx-s);
      margin-bottom: 6px;
    }

    /* input wrapper for icon + input */
    .input-wrap {
      position: relative;
    }

    .input-wrap svg.fi {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      width: 15px;
      height: 15px;
      color: var(--tx-m);
      pointer-events: none;
      transition: color .2s;
    }

    .input-wrap:focus-within svg.fi {
      color: var(--indigo);
    }

    .input-wrap input {
      width: 100%;
      padding: 10px 12px 10px 36px;
      font-family: inherit;
      font-size: .875rem;
      color: var(--tx);
      background: var(--surface-2);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      outline: none;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }

    .input-wrap input::placeholder {
      color: var(--tx-m);
    }

    .input-wrap input:focus {
      border-color: rgba(79, 70, 229, .42);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, .09);
    }

    /* eye toggle for password */
    .eye {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: var(--tx-m);
      border-radius: 6px;
      transition: color .18s, background .18s;
      display: flex;
      align-items: center;
    }

    .eye:hover {
      color: var(--indigo);
      background: var(--indigo-l);
    }

    .eye svg {
      width: 15px;
      height: 15px;
    }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 1.25rem 0;
    }

    .submit-btn {
      width: 100%;
      padding: 11px;
      background: linear-gradient(135deg, var(--coral), #fb923c);
      color: #fff;
      border: none;
      border-radius: 11px;
      font-family: inherit;
      font-size: .9rem;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      transition: all .22s;
      box-shadow: 0 4px 16px rgba(249, 115, 22, .28);
    }

    .submit-btn svg {
      width: 16px;
      height: 16px;
    }

    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(249, 115, 22, .36);
    }

    .submit-btn:active {
      transform: translateY(0);
    }

    /* error message (show when EJS passes an error) */
    .err-box {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--red-l);
      border: 1.5px solid rgba(225, 29, 72, .18);
      border-radius: 10px;
      padding: .65rem .9rem;
      font-size: .8rem;
      color: var(--red);
      font-weight: 500;
      margin-bottom: 1.1rem;
    }

    .err-box svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    .back-link {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      margin-top: 1.25rem;
      font-size: .78rem;
      color: var(--tx-m);
      text-decoration: none;
      transition: color .18s;
    }

    .back-link:hover {
      color: var(--indigo);
    }

    .back-link svg {
      width: 13px;
      height: 13px;
    }

    @keyframes up {
      from {
        opacity: 0;
        transform: translateY(22px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    @keyframes pop {
      from {
        opacity: 0;
        transform: scale(.7) rotate(-8deg)
      }

      to {
        opacity: 1;
        transform: scale(1) rotate(0)
      }
    }
  </style>
</head>

<body>

  <div class="wrap">

    <div class="hero">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
          stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </div>
      <h1>Admin <span>Login</span></h1>
      <p>Notice Board Management Portal</p>
    </div>

    <div class="card">

      <!-- show this block only when login fails — wire up via EJS -->
      <% if(typeof error !=='undefined' && error){ %>
        <div class="err-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          Invalid credentials. Please try again.
        </div>
        <% } %>

          <form method="post" action="/login">

            <div class="field">
              <label for="id">Admin ID</label>
              <div class="input-wrap">
                <svg class="fi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
                <input type="text" id="id" name="id" placeholder="Enter your admin ID" required
                  autocomplete="username" />
              </div>
            </div>

            <div class="field" style="margin-top:.85rem">
              <label for="password">Password</label>
              <div class="input-wrap">
                <svg class="fi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                <input type="password" id="password" name="password" placeholder="Enter your password" required
                  autocomplete="current-password" />
                <button type="button" class="eye" id="eyeBtn" title="Show/hide password">
                  <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                </button>
              </div>
            </div>

            <div class="divider"></div>

            <button type="submit" class="submit-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                stroke-linejoin="round">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                <polyline points="10 17 15 12 10 7" />
                <line x1="15" y1="12" x2="3" y2="12" />
              </svg>
              Login to Dashboard
            </button>

          </form>
    </div>

    <a href="/" class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
        stroke-linejoin="round">
        <path d="M19 12H5M12 5l-7 7 7 7" />
      </svg>
      Back to home
    </a>

  </div>

  <script>
    const pwd = document.getElementById('password');
    const icon = document.getElementById('eyeIcon');

    document.getElementById('eyeBtn').addEventListener('click', () => {
      const show = pwd.type === 'password';
      pwd.type = show ? 'text' : 'password';
      icon.innerHTML = show
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    });
  </script>
</body>

</html>