<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Notice — NotiFy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/edit.css">
</head>
<body>

  <!-- Loading overlay -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner"></div>
    <div class="loading-text" id="loadingText">Changes save ho rahe hain...</div>
  </div>

  <div class="bg-layer">
    <div class="bg-bar"></div>
    <div class="bg-card"></div><div class="bg-card"></div><div class="bg-card"></div>
  </div>

  <div class="backdrop" onclick="window.location='/admin'"></div>

  <div class="modal-wrap">
    <div class="modal">

      <!-- Header -->
      <div class="modal-header">
        <div class="modal-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <div class="modal-title-wrap">
          <div class="modal-title">
            Edit <span>Notice</span>
            <span class="unsaved-badge" id="unsavedBadge">Unsaved</span>
          </div>
          <p class="modal-sub">ID #<%= n.id %> &nbsp;·&nbsp; <%= n.department %></p>
        </div>
        <a href="/admin" class="close-btn" title="Close (Esc)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </a>
      </div>

      <!-- Body -->
      <div class="modal-body">
        <form action="/admin/<%= n.id %>?_method=PATCH" method="POST" enctype="multipart/form-data" id="editForm" novalidate>

          <p class="section-label">Notice Details</p>

          <div class="field-group">
            <label for="title">Title <span class="req">*</span></label>
            <input type="text" id="title" name="title" value="<%= n.title %>" required />
          </div>

          <div class="field-group">
            <label for="description">Description <span class="req">*</span></label>
            <textarea id="description" name="description" required><%= n.description %></textarea>
          </div>

          <div class="form-divider"></div>
          <p class="section-label">Attachment</p>

          <% if(n.url) { %>
          <div class="current-file">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
            <a href="<%= n.url %>" target="_blank" rel="noopener">Current attachment ↗</a>
          </div>
          <% } %>

          <div class="field-group">
            <label for="file">Replace File <span class="opt">(optional)</span></label>
            <div class="drop-zone" id="dropZone">
              <input type="file" id="file" name="file" accept="image/jpeg,image/png,image/webp,.pdf" />
              <div class="drop-text"> Upload here a new file</div>
              <div class="drop-sub">JPG, PNG, WEBP, PDF — max 5MB</div>
            </div>
            <div class="file-preview" id="filePreview">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span id="fileName"></span>
              <button type="button" class="file-remove" id="fileRemove">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          </div>

          <div class="form-divider"></div>
          <p class="section-label">Author Info</p>

          <div class="field-row">
            <div class="field-group">
              <label for="author">Author <span class="req">*</span></label>
              <input type="text" id="author" name="author" value="<%= n.author %>" required />
            </div>
            <div class="field-group">
              <label for="department">Department <span class="req">*</span></label>
              <input type="text" id="department" name="department" value="<%= n.department %>" required />
            </div>
          </div>

        </form>
      </div>

      <!-- Footer -->
      <div class="modal-footer">
        <a href="/admin" class="btn-cancel">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          Cancel
        </a>
        <button type="submit" form="editForm" class="btn-save" id="saveBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save Changes
        </button>
      </div>

    </div>
  </div>

  <script>
    // Dirty tracking 
    const fields = document.querySelectorAll('#editForm input:not([type="file"]), #editForm textarea');
    const badge  = document.getElementById('unsavedBadge');
    const origVals = {};
    fields.forEach(f => origVals[f.id] = f.value);
    fields.forEach(f => {
      f.addEventListener('input', () => {
        f.classList.toggle('dirty', f.value !== origVals[f.id]);
        badge.classList.toggle('show', [...fields].some(x => x.value !== origVals[x.id]));
      });
    });

    //  File drop zone
    const dropZone    = document.getElementById('dropZone');
    const fileInput   = document.getElementById('file');
    const filePreview = document.getElementById('filePreview');
    const fileName    = document.getElementById('fileName');
    const fileRemove  = document.getElementById('fileRemove');

    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) showFile(fileInput.files[0]);
    });
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault(); dropZone.classList.remove('drag-over');
      const f = e.dataTransfer.files[0];
      if (f) { const dt = new DataTransfer(); dt.items.add(f); fileInput.files = dt.files; showFile(f); }
    });
    fileRemove.addEventListener('click', () => {
      fileInput.value = ''; filePreview.classList.remove('show'); dropZone.style.display = '';
    });
    function showFile(f) {
      fileName.textContent = f.name; filePreview.classList.add('show'); dropZone.style.display = 'none';
      badge.classList.add('show');
    }

    // Submit 
    document.getElementById('editForm').addEventListener('submit', function() {
      const hasFile = fileInput.files.length > 0;
      document.getElementById('loadingText').textContent = hasFile ? 'File upload ho rahi hai...' : 'Changes save ho rahe hain...';
      document.getElementById('loadingOverlay').classList.add('show');
      document.getElementById('saveBtn').disabled = true;
    });

    // ESC to close
    document.addEventListener('keydown', e => { if (e.key === 'Escape') window.location = '/admin'; });
  </script>

</body>
</html>
