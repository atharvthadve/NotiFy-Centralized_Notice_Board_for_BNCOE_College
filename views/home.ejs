<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notice Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
       box-sizing: border-box; margin: 0; padding: 0; 
      }

    :root {
      --indigo:       #4f46e5;
      --indigo-dark:  #3730a3;
      --indigo-light: #eef2ff;
      --indigo-mid:   #818cf8;
      --coral:        #f97316;
      --coral-light:  #fff7ed;
      --teal:         #0d9488;
      --teal-light:   #f0fdfa;
      --bg:           #f8f7ff;
      --surface:      #ffffff;
      --border:       rgba(79,70,229,0.10);
      --text-dark:    #1e1b4b;
      --text-soft:    #6d6a8a;
      --text-muted:   #a5a3bb;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      top: -140px; left: -140px;
      width: 520px; height: 520px;
      background: radial-gradient(circle, rgba(99,102,241,0.13) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -100px; right: -100px;
      width: 420px; height: 420px;
      background: radial-gradient(circle, rgba(249,115,22,0.09) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 440px;
      animation: riseUp 0.7s cubic-bezier(.22,1,.36,1) both;
    }

    .hero {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .logo-ring {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 74px; height: 74px;
      background: linear-gradient(135deg, var(--indigo) 0%, #7c3aed 100%);
      border-radius: 22px;
      box-shadow: 0 10px 36px rgba(79,70,229,0.32);
      margin-bottom: 1.4rem;
      animation: popIn 0.6s 0.15s cubic-bezier(.34,1.56,.64,1) both;
    }

    .logo-ring svg { width: 34px; height: 34px; color: #fff; }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--text-dark);
      letter-spacing: -0.03em;
      line-height: 1.15;
    }

    .hero h1 span { color: var(--indigo); }

    .hero p {
      margin-top: 0.55rem;
      font-size: 0.9rem;
      color: var(--text-soft);
      font-weight: 300;
    }

    .glass-card {
      background: var(--surface);
      border-radius: 24px;
      border: 1.5px solid rgba(79,70,229,0.11);
      box-shadow: 0 10px 48px rgba(79,70,229,0.09), 0 2px 8px rgba(0,0,0,0.04);
      padding: 2rem;
    }

    .section-label {
      font-size: 0.69rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.1rem 1.2rem;
      border-radius: 14px;
      text-decoration: none;
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
      margin-bottom: 0.85rem;
      border: 1.5px solid transparent;
    }

    .nav-btn:last-child { margin-bottom: 0; }
    .nav-btn:hover { transform: translateY(-3px); }
    .nav-btn:active { transform: translateY(0); }

    .nav-btn.student {
      background: linear-gradient(135deg, #eef2ff 0%, #f0f4ff 100%);
      border-color: rgba(79,70,229,0.16);
    }
    .nav-btn.student:hover {
      box-shadow: 0 8px 28px rgba(79,70,229,0.16);
      border-color: rgba(79,70,229,0.32);
    }

    .nav-btn.admin {
      background: linear-gradient(135deg, #fff7ed 0%, #fff4e6 100%);
      border-color: rgba(249,115,22,0.16);
    }
    .nav-btn.admin:hover {
      box-shadow: 0 8px 28px rgba(249,115,22,0.16);
      border-color: rgba(249,115,22,0.32);
    }

    .btn-icon {
      width: 46px; height: 46px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .student .btn-icon { background: rgba(79,70,229,0.12); }
    .admin   .btn-icon { background: rgba(249,115,22,0.12); }
    .btn-icon svg { width: 22px; height: 22px; }
    .student .btn-icon svg { color: var(--indigo); }
    .admin   .btn-icon svg { color: var(--coral); }

    .btn-text { flex: 1; }

    .btn-text strong {
      display: block;
      font-size: 0.96rem;
      font-weight: 600;
    }

    .student .btn-text strong { color: #1e1b4b; }
    .admin   .btn-text strong { color: #7c2d12; }

    .btn-text span {
      font-size: 0.78rem;
      font-weight: 300;
    }
    .student .btn-text span { color: var(--text-soft); }
    .admin   .btn-text span { color: #c2603a; }

    .btn-arrow { transition: transform 0.2s; }
    .nav-btn:hover .btn-arrow { transform: translateX(5px); }
    .btn-arrow svg { width: 18px; height: 18px; }
    .student .btn-arrow svg { color: var(--indigo-mid); }
    .admin   .btn-arrow svg { color: var(--coral); }

    .or-divider {
      display: flex; align-items: center; gap: 0.75rem;
      color: var(--text-muted); font-size: 0.74rem;
      margin: 0.9rem 0;
    }
    .or-divider::before, .or-divider::after {
      content: ''; flex: 1; height: 1px;
      background: rgba(79,70,229,0.09);
    }

    .footer {
      text-align: center;
      margin-top: 1.75rem;
      font-size: 0.74rem;
      color: var(--text-muted);
      animation: riseUp 0.6s 0.3s ease both;
    }

    @keyframes riseUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(0.7) rotate(-10deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }
  </style>
</head>
<body>
<div class="wrap">

  <div class="hero">
    <div class="logo-ring">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </div>
    <p>Stay updated with the latest announcements</p>
  </div>

  <div class="glass-card">
    <p class="section-label">Select your portal</p>

    <a href="/student" class="nav-btn student">
      <div class="btn-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div class="btn-text">
        <strong>Student Dashboard</strong>
        <span>View notices &amp; announcements</span>
      </div>
      <div class="btn-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
    </a>

    <div class="or-divider">or</div>

    <a href="/admin" class="nav-btn admin">
      <div class="btn-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="3"/>
          <path d="M20 21a8 8 0 1 0-16 0"/>
          <path d="M17 13l2 2 4-4"/>
        </svg>
      </div>
      <div class="btn-text">
        <strong>Admin Panel</strong>
        <span>Post &amp; manage notices</span>
      </div>
      <div class="btn-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
    </a>
  </div>

  <div class="footer">&copy; <%= new Date().getFullYear() %> BNCOE. All Rights Reserved</div>
</div>
</body>
</html>
