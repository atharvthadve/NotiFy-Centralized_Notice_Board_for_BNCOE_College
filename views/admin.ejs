<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Panel — Notice Board</title>
  <link rel="stylesheet" href="admin.css">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
</head>

<body>

  <!-- Topbar -->
  <nav class="topbar">
    <div class="topbar-brand">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
          stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="3" />
          <path d="M9 9h6M9 12h6M9 15h4" />
        </svg>
      </div>
      <span class="brand-name">Notice Board</span>
      <span class="admin-chip">Admin</span>
    </div>

    <div class="topbar-right">
      <a href="/createpost" class="btn-create">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19" />
          <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Create Notice
      </a>
      <a href="/logout" class="btn-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
          <polyline points="16 17 21 12 16 7" />
          <line x1="21" y1="12" x2="9" y2="12" />
        </svg>
        Logout
      </a>
    </div>
  </nav>

  <!-- Notices -->
  <div class="notices-wrap">

    <% if (notices.length===0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="9" y1="13" x2="15" y2="13" />
            <line x1="9" y1="17" x2="12" y2="17" />
          </svg>
        </div>
        <h3>No notices yet</h3>
        <p>Create your first notice to get started.</p>
        <a href="/createpost" class="empty-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Create Notice
        </a>
      </div>
      <% } %>

        <% notices.forEach((n, i)=> { %>
          <div class="notice-card">
            <div class="card-body">
              <div class="card-num">
                <%= i + 1 %>
              </div>
              <div class="card-content">
                <div class="dept-pill">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                    <path d="M6 12v5c3 3 9 3 12 0v-5" />
                  </svg>
                  <%= n.department %>
                </div>
                <div class="card-title">
                  <%= n.title %>
                </div>
                <div class="card-desc" style="white-space: pre-line;">
                  <%= n.description %>
                </div>
              </div>
            </div>

            <div class="card-footer">
              <div class="meta-row">
                <div class="meta-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                  <strong>
                    <%= n.author %>
                  </strong>
                </div>
                <% if (n.createdAt) { %>
                  <div class="meta-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                      stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    <%= new Date(n.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric'
                      }) %>
                  </div>
                  <% } %>
              </div>

              <div class="action-row">
                <a href="/admin/<%= n.id %>" class="act-btn act-edit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                  </svg>
                  Edit
                </a>
                <form action="/admin/<%= n.id %>?_method=DELETE" method="post">
                  <button type="submit" class="act-btn act-delete" onclick="return confirm('Delete this notice?')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                      stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6" />
                      <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                      <path d="M10 11v6M14 11v6" />
                      <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                    </svg>
                    Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
          <% }) %>

  </div>

<!-- # Skeleton Loading  -->
  <style>
    .skeleton-wrap {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: 1.2rem;
    }
    .skel-card {
      background: #fff;
      border-radius: 14px;
      padding: 1.4rem 1.6rem;
      border: 1px solid rgba(79,70,229,.09);
      box-shadow: 0 1px 4px rgba(79,70,229,.06);
      display: flex;
      align-items: flex-start;
      gap: 1.2rem;
    }
    .skel-num {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: linear-gradient(90deg, #e8e6f8 25%, #f3f2fc 50%, #e8e6f8 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      flex-shrink: 0;
    }
    .skel-body { flex: 1; }
    .skel-line {
      background: linear-gradient(90deg, #e8e6f8 25%, #f3f2fc 50%, #e8e6f8 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 6px;
      height: 13px;
      margin-bottom: 10px;
    }
    .skel-line.pill  { height: 22px; width: 90px; border-radius: 20px; margin-bottom: 12px; }
    .skel-line.title { height: 18px; width: 55%; margin-bottom: 12px; }
    .skel-line.full  { width: 100%; }
    .skel-line.med   { width: 70%; }
    .skel-line.short { width: 38%; }
    .skel-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 14px;
    }
    .skel-btn {
      width: 70px; height: 30px;
      border-radius: 8px;
      background: linear-gradient(90deg, #e8e6f8 25%, #f3f2fc 50%, #e8e6f8 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
    }
    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
  </style>

  <script>
    (function() {
      const wrap = document.querySelector('.notices-wrap');
      if (!wrap) return;

      const skWrap = document.createElement('div');
      skWrap.className = 'skeleton-wrap';
      skWrap.id = 'admin-skeleton';

      for (let i = 0; i < 5; i++) {
        skWrap.innerHTML += `
          <div class="skel-card">
            <div class="skel-num"></div>
            <div class="skel-body">
              <div class="skel-line pill"></div>
              <div class="skel-line title"></div>
              <div class="skel-line full"></div>
              <div class="skel-line med"></div>
              <div class="skel-foot">
                <div class="skel-line short" style="margin:0;"></div>
                <div style="display:flex;gap:8px;">
                  <div class="skel-btn"></div>
                  <div class="skel-btn"></div>
                </div>
              </div>
            </div>
          </div>`;
      }

      wrap.style.visibility = 'hidden';
      wrap.style.position = 'absolute';
      wrap.parentNode.insertBefore(skWrap, wrap);

      window.addEventListener('load', function() {
        const sk = document.getElementById('admin-skeleton');
        if (sk) sk.remove();
        wrap.style.visibility = '';
        wrap.style.position = '';
      });
    })();
  </script>

</body>

</html>