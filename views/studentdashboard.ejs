<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard — Notice Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --indigo: #4f46e5;
      --indigo-d: #3730a3;
      --indigo-l: #eef2ff;
      --indigo-m: #818cf8;
      --coral: #f97316;
      --coral-l: #fff7ed;
      --teal: #0d9488;
      --teal-l: #f0fdfa;
      --violet: #7c3aed;
      --bg: #f8f7ff;
      --surface: #fff;
      --surface-2: #f9f8ff;
      --border: rgba(79, 70, 229, .09);
      --border-h: rgba(79, 70, 229, .20);
      --tx: #1e1b4b;
      --tx-s: #6d6a8a;
      --tx-m: #a5a3bb;
      --sh-sm: 0 1px 4px rgba(79, 70, 229, .06);
      --sh-md: 0 6px 24px rgba(79, 70, 229, .10), 0 2px 6px rgba(0, 0, 0, .04);
      --r: 16px;
      --r-sm: 10px;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--tx);
      padding-bottom: 4rem;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 99;
      height: 60px;
      padding: 0 1.5rem;
      background: rgba(255, 255, 255, .92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      animation: dn .4s ease both;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 9px;
      text-decoration: none;
    }

    .brand-icon {
      width: 34px;
      height: 34px;
      border-radius: 9px;
      background: linear-gradient(135deg, var(--indigo), var(--violet));
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 12px rgba(79, 70, 229, .28);
    }

    .brand-icon svg {
      width: 17px;
      height: 17px;
      color: #fff;
    }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--tx);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .badge {
      font-size: .72rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 20px;
      background: var(--indigo-l);
      color: var(--indigo);
      border: 1px solid rgba(79, 70, 229, .15);
    }

    .home-link {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: .79rem;
      font-weight: 500;
      color: var(--tx-s);
      text-decoration: none;
      padding: 5px 9px;
      border-radius: 8px;
      transition: all .18s;
    }

    .home-link:hover {
      background: var(--indigo-l);
      color: var(--indigo);
    }

    .home-link svg {
      width: 13px;
      height: 13px;
    }

    /* toolbar */
    .toolbar {
      max-width: 1060px;
      margin: 1.75rem auto 0;
      padding: 0 1.5rem;
      animation: up .5s .1s ease both;
    }

    /* search bar — pill with search, clear, divider, sort toggles */
    .search-bar {
      display: flex;
      align-items: center;
      background: var(--surface);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      box-shadow: var(--sh-sm);
      transition: border-color .2s, box-shadow .2s;
      overflow: hidden;
    }

    .search-bar:focus-within {
      border-color: rgba(79, 70, 229, .35);
      box-shadow: 0 0 0 3px rgba(79, 70, 229, .08), var(--sh-sm);
    }

    .s-ic {
      width: 15px;
      height: 15px;
      color: var(--tx-m);
      flex-shrink: 0;
      margin-left: 14px;
      transition: color .2s;
      pointer-events: none;
    }

    .search-bar:focus-within .s-ic {
      color: var(--indigo);
    }

    #q {
      flex: 1;
      padding: 12px 8px;
      font-family: inherit;
      font-size: .875rem;
      color: var(--tx);
      background: transparent;
      border: none;
      outline: none;
    }

    #q::placeholder {
      color: var(--tx-m);
    }

    .x-btn {
      width: 28px;
      height: 28px;
      border-radius: 7px;
      margin-right: 4px;
      flex-shrink: 0;
      background: transparent;
      border: none;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      color: var(--tx-m);
      transition: all .16s;
    }

    .x-btn.on {
      display: flex;
    }

    .x-btn:hover {
      background: var(--indigo-l);
      color: var(--indigo);
    }

    .x-btn svg {
      width: 11px;
      height: 11px;
    }

    .bar-div {
      width: 1px;
      height: 22px;
      background: var(--border);
      flex-shrink: 0;
    }

    /* newest / oldest toggle pair */
    .sort-toggle {
      display: flex;
      align-items: center;
      padding: 5px 8px;
      gap: 3px;
      flex-shrink: 0;
    }

    .sort-btn {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 5px 11px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      background: transparent;
      font-family: inherit;
      font-size: .78rem;
      font-weight: 500;
      color: var(--tx-m);
      transition: all .16s;
      white-space: nowrap;
    }

    .sort-btn svg {
      width: 12px;
      height: 12px;
    }

    .sort-btn:hover {
      background: var(--surface-2);
      color: var(--tx-s);
    }

    .sort-btn.on {
      background: var(--indigo-l);
      color: var(--indigo);
      font-weight: 600;
    }

    /* date strip */
    .date-strip {
      display: flex;
      align-items: center;
      gap: .6rem;
      margin-top: .6rem;
      padding: .55rem 1rem;
      background: var(--surface);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--sh-sm);
    }

    .f-lbl {
      font-size: .63rem;
      font-weight: 700;
      letter-spacing: .09em;
      text-transform: uppercase;
      color: var(--tx-m);
      flex-shrink: 0;
    }

    .date-wrap {
      display: flex;
      align-items: center;
      gap: .35rem;
      flex: 1;
    }

    input[type="date"] {
      flex: 1;
      min-width: 0;
      padding: 5px 8px;
      font-family: inherit;
      font-size: .78rem;
      color: var(--tx-s);
      background: var(--surface-2);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      outline: none;
      cursor: pointer;
      transition: border-color .2s, box-shadow .2s;
    }

    input[type="date"]:focus {
      border-color: rgba(79, 70, 229, .4);
      box-shadow: 0 0 0 3px rgba(79, 70, 229, .08);
    }

    input[type="date"]::-webkit-calendar-picker-indicator {
      opacity: .4;
      cursor: pointer;
    }

    .date-sep {
      font-size: .7rem;
      color: var(--tx-m);
      flex-shrink: 0;
    }

    .dclr {
      width: 22px;
      height: 22px;
      border-radius: 7px;
      flex-shrink: 0;
      background: transparent;
      border: none;
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      color: var(--tx-m);
      transition: all .16s;
    }

    .dclr.on {
      display: flex;
    }

    .dclr:hover {
      background: var(--indigo-l);
      color: var(--indigo);
    }

    .dclr svg {
      width: 10px;
      height: 10px;
    }

    /* results bar */
    .rbar {
      max-width: 1060px;
      margin: .65rem auto 0;
      padding: 0 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .rbar p {
      font-size: .74rem;
      color: var(--tx-m);
    }

    .rbar p strong {
      color: var(--tx-s);
    }

    .rst {
      display: none;
      align-items: center;
      gap: 4px;
      font-size: .74rem;
      font-weight: 500;
      color: var(--indigo);
      border: none;
      background: none;
      cursor: pointer;
      font-family: inherit;
      transition: opacity .18s;
    }

    .rst.on {
      display: inline-flex;
    }

    .rst:hover {
      opacity: .65;
    }

    .rst svg {
      width: 11px;
      height: 11px;
    }

    /* notices */
    .list {
      max-width: 1060px;
      margin: 1.25rem auto 0;
      padding: 0 1.5rem;
    }

    .empty,
    .none {
      text-align: center;
      padding: 4rem 2rem;
    }

    .none {
      display: none;
    }

    .none.on {
      display: block;
    }

    .state-icon {
      width: 58px;
      height: 58px;
      border-radius: 16px;
      background: var(--indigo-l);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
    }

    .state-icon svg {
      width: 26px;
      height: 26px;
      color: var(--indigo-m);
    }

    .empty h3,
    .none h3 {
      font-size: .95rem;
      font-weight: 600;
    }

    .empty p,
    .none p {
      margin-top: .3rem;
      font-size: .82rem;
      color: var(--tx-m);
    }

    .card {
      background: var(--surface);
      border-radius: var(--r);
      border: 1.5px solid var(--border);
      box-shadow: var(--sh-sm);
      margin-bottom: 1.1rem;
      overflow: hidden;
      transition: transform .22s, box-shadow .22s, border-color .22s;
      animation: up .5s ease both;
    }

    .card.hide {
      display: none !important;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--sh-md);
      border-color: var(--border-h);
    }

    .card-body {
      padding: 1.2rem 1.4rem 1rem;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .07em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 20px;
      margin-bottom: .7rem;
    }

    .card:nth-child(4n+1) .pill {
      background: var(--indigo-l);
      color: var(--indigo);
    }

    .card:nth-child(4n+2) .pill {
      background: var(--coral-l);
      color: var(--coral);
    }

    .card:nth-child(4n+3) .pill {
      background: var(--teal-l);
      color: var(--teal);
    }

    .card:nth-child(4n+0) .pill {
      background: #f5f3ff;
      color: var(--violet);
    }

    .pill svg {
      width: 10px;
      height: 10px;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: .4rem;
    }

    .card-desc {
      font-size: .845rem;
      color: var(--tx-s);
      line-height: 1.65;
      font-weight: 300;
    }

    mark {
      background: rgba(79, 70, 229, .13);
      color: var(--indigo);
      border-radius: 3px;
      padding: 0 2px;
    }

    .preview {
      margin: .8rem 1.4rem;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      overflow-x: hidden;
      overflow-y: auto;
      max-height: 300px;
    }

    .preview::-webkit-scrollbar {
      width: 4px;
    }

    .preview::-webkit-scrollbar-thumb {
      background: #c7c5e8;
      border-radius: 10px;
    }

    .preview iframe {
      width: 100%;
      height: 580px;
      border: none;
      display: block;
    }

    .preview img {
      width: 100%;
      height: auto;
      display: block;
    }

    .card-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: .8rem 1.4rem;
      border-top: 1px solid var(--border);
      background: var(--surface-2);
      gap: .75rem;
      flex-wrap: wrap;
    }

    .meta {
      display: flex;
      align-items: center;
      gap: .85rem;
      flex-wrap: wrap;
    }

    .mi {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: .75rem;
      color: var(--tx-m);
    }

    .mi svg {
      width: 12px;
      height: 12px;
    }

    .mi strong {
      color: var(--tx-s);
      font-weight: 500;
    }

    .open-btn {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 13px;
      background: var(--indigo);
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-size: .77rem;
      font-weight: 500;
      transition: all .2s;
      flex-shrink: 0;
    }

    .open-btn:hover {
      background: var(--indigo-d);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(79, 70, 229, .28);
    }

    .open-btn svg {
      width: 12px;
      height: 12px;
    }

    .card:nth-child(1) {
      animation-delay: .06s
    }

    .card:nth-child(2) {
      animation-delay: .12s
    }

    .card:nth-child(3) {
      animation-delay: .18s
    }

    .card:nth-child(4) {
      animation-delay: .24s
    }

    .card:nth-child(5) {
      animation-delay: .30s
    }

    .card:nth-child(6) {
      animation-delay: .36s
    }

    @keyframes dn {
      from {
        opacity: 0;
        transform: translateY(-12px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    @keyframes up {
      from {
        opacity: 0;
        transform: translateY(14px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }
  </style>
</head>

<body>

  <nav class="topbar">
    <a href="/" class="brand">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
      </div>
      <span class="brand-name">Notice Board</span>
    </a>
    <div class="topbar-right">
      <span class="badge" id="badge">
        <%= notices.length %> notice<%= notices.length!==1?'s':'' %>
      </span>
      <a href="/" class="home-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Home
      </a>
    </div>
  </nav>

  <div class="toolbar">

    <div class="search-bar">
      <svg class="s-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input id="q" type="text" placeholder="Search notices…" autocomplete="off" />
      <button class="x-btn" id="xb">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
      <div class="bar-div"></div>
      <div class="sort-toggle">
        <button class="sort-btn on" id="sNew">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <polyline points="19 12 12 19 5 12" />
          </svg>
          Newest
        </button>
        <button class="sort-btn" id="sOld">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="12" y1="19" x2="12" y2="5" />
            <polyline points="5 12 12 5 19 12" />
          </svg>
          Oldest
        </button>
      </div>
    </div>

    <div class="date-strip">
      <span class="f-lbl">Date</span>
      <div class="date-wrap">
        <input type="date" id="d1" />
        <span class="date-sep">→</span>
        <input type="date" id="d2" />
      </div>
      <button class="dclr" id="dclr">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

  </div>

  <div class="rbar">
    <p>Showing <strong id="vc">
        <%= notices.length %>
      </strong> of <strong>
        <%= notices.length %>
      </strong></p>
    <button class="rst" id="rst">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
        stroke-linejoin="round">
        <polyline points="1 4 1 10 7 10" />
        <path d="M3.51 15a9 9 0 1 0 .49-3.5" />
      </svg>
      Reset
    </button>
  </div>

  <div class="list" id="list">

    <% if(notices.length===0){ %>
      <div class="empty">
        <div class="state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="9" y1="13" x2="15" y2="13" />
            <line x1="9" y1="17" x2="12" y2="17" />
          </svg>
        </div>
        <h3>No notices yet</h3>
        <p>Check back soon for new announcements.</p>
      </div>
      <% } %>

        <div class="none" id="none">
          <div class="state-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
              <line x1="8" y1="11" x2="14" y2="11" />
            </svg>
          </div>
          <h3>No matches</h3>
          <p>Try a different keyword or clear filters.</p>
        </div>

        <% notices.forEach((n,i)=>{ %>
          <div class="card" data-t="<%= n.title.toLowerCase() %>" data-d="<%= n.description.toLowerCase() %>"
            data-a="<%= n.author.toLowerCase() %>" data-dept="<%= n.department.toLowerCase() %>"
            data-ts="<%= new Date(n.createdAt).getTime() %>">

            <div class="card-body">
              <div class="pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                  <path d="M6 12v5c3 3 9 3 12 0v-5" />
                </svg>
                <%= n.department %>
              </div>
              <div class="card-title">
                <%= n.title %>
              </div>
              <div class="card-desc" style="white-space: pre-line;">
                <%= n.description %>
              </div>
            </div>

            <% if(n.url){ %>
              <div class="preview">
                <% if(/\.(jpg|jpeg|png|webp|gif)$/i.test(n.url)){ %>
                  <img src="<%= n.url %>" loading="lazy" alt="" />
                  <% } else { %>
                    <iframe src="<%= n.url %>" loading="lazy" title="preview"></iframe>
                    <% } %>
              </div>
              <% } %>

                <div class="card-foot">
                  <div class="meta">
                    <span class="mi">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                      </svg>
                      <strong>
                        <%= n.author %>
                      </strong>
                    </span>
                    <span class="mi">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      <%= new Date(n.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})
                        %>
                    </span>
                  </div>
                  <% if(n.url){ %>
                    <a href="<%= n.url %>" target="_blank" rel="noopener" class="open-btn">
                      Open
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                    </a>
                    <% } %>
                </div>
          </div>
          <% }) %>
  </div>

  <script>
    const cards = [...document.querySelectorAll('.card')];
    const qEl = document.getElementById('q');
    const xb = document.getElementById('xb');
    const sNew = document.getElementById('sNew');
    const sOld = document.getElementById('sOld');
    const noEl = document.getElementById('none');
    const vcEl = document.getElementById('vc');
    const rstEl = document.getElementById('rst');
    const bdg = document.getElementById('badge');
    const list = document.getElementById('list');
    const d1 = document.getElementById('d1');
    const d2 = document.getElementById('d2');
    const dclr = document.getElementById('dclr');

    let q = '', sort = 'new';

    function run() {
      const from = d1.value ? new Date(d1.value).setHours(0, 0, 0, 0) : null;
      const to = d2.value ? new Date(d2.value).setHours(23, 59, 59, 0) : null;

      const vis = cards.filter(c => {
        const ts = +c.dataset.ts;
        const ok = (!q || [c.dataset.t, c.dataset.d, c.dataset.a, c.dataset.dept].some(v => v.includes(q)))
          && (!from || ts >= from)
          && (!to || ts <= to);
        c.classList.toggle('hide', !ok);
        return ok;
      });

      vis.sort((a, b) => sort === 'new' ? b.dataset.ts - a.dataset.ts : a.dataset.ts - b.dataset.ts);
      vis.forEach(c => list.appendChild(c));

      cards.forEach(c => {
        ['card-title', 'card-desc'].forEach(cls => {
          const el = c.querySelector('.' + cls);
          if (!el.dataset.o) el.dataset.o = el.textContent;
          el.innerHTML = q
            ? el.dataset.o.replace(new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'), '<mark>$1</mark>')
            : el.dataset.o;
        });
      });

      const n = vis.length;
      vcEl.textContent = n;
      bdg.textContent = n + ' notice' + (n !== 1 ? 's' : '');
      noEl.classList.toggle('on', !n && cards.length > 0);
      rstEl.classList.toggle('on', !!(q || sort !== 'new' || d1.value || d2.value));
    }

    qEl.addEventListener('input', () => { q = qEl.value.toLowerCase().trim(); xb.classList.toggle('on', !!q); run(); });
    xb.addEventListener('click', () => { qEl.value = q = ''; xb.classList.remove('on'); qEl.focus(); run(); });

    sNew.addEventListener('click', () => { sort = 'new'; sNew.classList.add('on'); sOld.classList.remove('on'); run(); });
    sOld.addEventListener('click', () => { sort = 'old'; sOld.classList.add('on'); sNew.classList.remove('on'); run(); });

    d1.addEventListener('change', () => { dclr.classList.toggle('on', !!(d1.value || d2.value)); run(); });
    d2.addEventListener('change', () => { dclr.classList.toggle('on', !!(d1.value || d2.value)); run(); });
    dclr.addEventListener('click', () => { d1.value = d2.value = ''; dclr.classList.remove('on'); run(); });

    rstEl.addEventListener('click', () => {
      qEl.value = q = ''; sort = 'new'; d1.value = d2.value = '';
      xb.classList.remove('on'); dclr.classList.remove('on');
      sNew.classList.add('on'); sOld.classList.remove('on');
      run();
    });

    run();
  </script>
</body>

</html>