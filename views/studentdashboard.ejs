<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard — Notice Board</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
       box-sizing: border-box; margin: 0; padding: 0;
       }

    :root {
      --indigo:       #4f46e5;
      --indigo-dark:  #3730a3;
      --indigo-light: #eef2ff;
      --indigo-mid:   #818cf8;
      --coral:        #f97316;
      --coral-light:  #fff7ed;
      --teal:         #0d9488;
      --teal-light:   #f0fdfa;
      --violet:       #7c3aed;
      --rose:         #e11d48;
      --rose-light:   #fff1f2;
      --amber:        #d97706;
      --amber-light:  #fffbeb;
      --green:        #059669;
      --green-light:  #ecfdf5;
      --bg:           #f8f7ff;
      --surface:      #ffffff;
      --surface-2:    #f9f8ff;
      --border:       rgba(79,70,229,0.09);
      --border-hover: rgba(79,70,229,0.20);
      --text-dark:    #1e1b4b;
      --text-soft:    #6d6a8a;
      --text-muted:   #a5a3bb;
      --shadow-sm: 0 1px 4px rgba(79,70,229,0.06);
      --shadow-md: 0 6px 24px rgba(79,70,229,0.10), 0 2px 6px rgba(0,0,0,0.04);
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      color: var(--text-dark);
      padding-bottom: 4rem;
    }

    /* ── Topbar ── */
    .topbar {
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      animation: slideDown 0.4s ease both;
    }

    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .brand-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--indigo), var(--violet));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 12px rgba(79,70,229,0.28);
    }

    .brand-icon svg { width: 18px; height: 18px; color: #fff; }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      color: var(--text-dark);
    }

    .topbar-right { display: flex; align-items: center; gap: 10px; }

    .count-badge {
      font-size: 0.74rem;
      font-weight: 600;
      padding: 4px 11px;
      border-radius: 20px;
      background: var(--indigo-light);
      color: var(--indigo);
      border: 1px solid rgba(79,70,229,0.15);
    }

    .home-link {
      display: flex; align-items: center; gap: 5px;
      font-size: 0.8rem; font-weight: 500;
      color: var(--text-soft);
      text-decoration: none;
      padding: 5px 10px;
      border-radius: 8px;
      transition: all 0.18s;
    }
    .home-link:hover { background: var(--indigo-light); color: var(--indigo); }
    .home-link svg { width: 14px; height: 14px; }

    /* Notices  */
    .notices-wrap {
      max-width: 880px;
      margin: 2rem auto 0;
      padding: 0 1.5rem;
    }

    /* Empty */
    .empty-state {
      text-align: center;
      padding: 5rem 2rem;
      animation: fadeUp 0.5s 0.2s ease both;
    }

    .empty-icon {
      width: 68px; height: 68px;
      background: var(--indigo-light);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.25rem;
    }
    .empty-icon svg { width: 30px; height: 30px; color: var(--indigo-mid); }
    .empty-state h3 { font-size: 1rem; font-weight: 600; color: var(--text-dark); }
    .empty-state p { margin-top: 0.35rem; font-size: 0.84rem; color: var(--text-muted); }

    /* Notice card */
    .notice-card {
      background: var(--surface);
      border-radius: 20px;
      border: 1.5px solid var(--border);
      box-shadow: var(--shadow-sm);
      margin-bottom: 1.25rem;
      overflow: hidden;
      transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
      animation: fadeUp 0.5s ease both;
    }

    .notice-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--border-hover);
    }

    .card-body { padding: 1.3rem 1.5rem 1.1rem; }

    /* Dept pill */
    .dept-pill {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 0.69rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 20px;
      margin-bottom: 0.8rem;
    }

    .notice-card:nth-child(4n+1) .dept-pill { background: var(--indigo-light); color: var(--indigo); }
    .notice-card:nth-child(4n+2) .dept-pill { background: var(--coral-light);  color: var(--coral);  }
    .notice-card:nth-child(4n+3) .dept-pill { background: var(--teal-light);   color: var(--teal);   }
    .notice-card:nth-child(4n+0) .dept-pill { background: #f5f3ff;             color: var(--violet); }
    .dept-pill svg { width: 11px; height: 11px; }

    .card-title {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--text-dark);
      line-height: 1.3;
      margin-bottom: 0.45rem;
    }

    .card-desc {
      font-size: 0.855rem;
      color: var(--text-soft);
      line-height: 1.65;
      font-weight: 300;
    }

    /* Preview */
    .preview-area {
      margin: 0.9rem 1.5rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      overflow-x: hidden;
      overflow-y: auto;
      max-height: 320px;
    }
    .preview-area::-webkit-scrollbar { width: 5px; }
    .preview-area::-webkit-scrollbar-track { background: transparent; }
    .preview-area::-webkit-scrollbar-thumb { background: #c7c5e8; border-radius: 10px; }

    .preview-area iframe { width: 100%; height: 600px; border: none; display: block; }
    .preview-area img    { width: 100%; height: auto; display: block; }

    /* Card footer */
    .card-footer {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1.5rem;
      border-top: 1px solid var(--border);
      background: var(--surface-2);
      gap: 1rem; flex-wrap: wrap;
    }

    .meta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }

    .meta-item {
      display: flex; align-items: center; gap: 5px;
      font-size: 0.77rem; color: var(--text-muted);
    }
    .meta-item svg { width: 13px; height: 13px; }
    .meta-item strong { color: var(--text-soft); font-weight: 500; }

    .open-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 15px;
      background: var(--indigo);
      color: #fff;
      border-radius: 9px;
      text-decoration: none;
      font-size: 0.79rem; font-weight: 500;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .open-btn:hover { background: var(--indigo-dark); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(79,70,229,0.28); }
    .open-btn svg { width: 13px; height: 13px; }

    /* Stagger */
    .notice-card:nth-child(1) { animation-delay: 0.08s; }
    .notice-card:nth-child(2) { animation-delay: 0.16s; }
    .notice-card:nth-child(3) { animation-delay: 0.24s; }
    .notice-card:nth-child(4) { animation-delay: 0.32s; }
    .notice-card:nth-child(5) { animation-delay: 0.40s; }
    .notice-card:nth-child(6) { animation-delay: 0.48s; }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

<nav class="topbar">
  <a href="/" class="topbar-brand">
    <div class="brand-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </div>
    <span class="brand-name">Notice Board</span>
  </a>
  <div class="topbar-right">
    <span class="count-badge"><%= notices.length %> notice<%= notices.length !== 1 ? 's' : '' %></span>
    <a href="/" class="home-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Home
    </a>
  </div>
</nav>

<div class="notices-wrap">

  <% if (notices.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="9" y1="13" x2="15" y2="13"/>
        <line x1="9" y1="17" x2="12" y2="17"/>
      </svg>
    </div>
    <h3>No notices yet</h3>
    <p>Check back soon for new announcements.</p>
  </div>
  <% } %>

  <% notices.forEach((n, i) => { %>
  <div class="notice-card">
    <div class="card-body">
      <div class="dept-pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
        <%= n.department %>
      </div>
      <div class="card-title"><%= n.title %></div>
      <div class="card-desc"><%= n.description %></div>
    </div>

    <% if (n.url) { %>
    <div class="preview-area">
      <% if (/\.(jpg|jpeg|png|webp|gif)$/i.test(n.url)) { %>
        <img src="<%= n.url %>" loading="lazy" alt="Notice image" />
      <% } else { %>
        <iframe src="<%= n.url %>" loading="lazy" title="Resource preview"></iframe>
      <% } %>
    </div>
    <% } %>

    <div class="card-footer">
      <div class="meta-row">
        <div class="meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <strong><%= n.author %></strong>
        </div>
        <div class="meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <%= new Date(n.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
          &nbsp;·&nbsp;
          <%= new Date(n.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %>
        </div>
      </div>
      <% if (n.url) { %>
      <a href="<%= n.url %>" target="_blank" rel="noopener" class="open-btn">
        Open Resource
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
      <% } %>
    </div>
  </div>
  <% }) %>

</div>
</body>
</html>
